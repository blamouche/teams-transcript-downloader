{
  "manifest_version": 3,
  "name": "Teams Transcript Downloader (Auto) v2",
  "version": "2.0.0",
  "description": "Télécharge automatiquement les transcripts de meetings Microsoft Teams (navigation auto + extraction manuelle de secours)",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "webNavigation",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://teams.microsoft.com/*",
        "https://teams.cloud.microsoft/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
